# Pulse environment template
# ---------------------------------------------------------------------------
# On Lovable Cloud these values are injected automatically. This file exists
# so that a local export (self-host) knows exactly what to configure.
# Never commit real secrets. Use Lovable's secret store or your platform's
# secret manager to inject production values.
# ---------------------------------------------------------------------------

# Client (Vite build-time, safe to expose)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Server (Cloudflare Worker / Node runtime, server-only)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY=""   # optional; verified privileged writes only
SUPABASE_PROJECT_ID="your-project-ref"

# Runtime
NODE_ENV="development"          # development | staging | preview | production | test
LOG_LEVEL="info"                # debug | info | warn | error

# Platform integrations (optional)
LOVABLE_API_KEY=""              # required only for connector-gateway calls
